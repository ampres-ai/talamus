# --- Agent / tooling runtime caches -----------------------------------------
.claude/
.worktrees/
# local tooling caches
.superpowers/

# --- Python -----------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/
.hypothesis/
.tox/
.nox/
.ipynb_checkpoints/

# Coverage
.coverage
.coverage.*
coverage.xml
htmlcov/

# --- Packaging --------------------------------------------------------------
build/
dist/
*.egg-info/
*.egg
pip-wheel-metadata/

# --- Virtual environments ---------------------------------------------------
.venv/
venv/
env/
ENV/
.python-version

# --- Secrets (never in the repo: keys live in TALAMUS_HOME or env) ----------
.env
.env.*
credentials.json
*.pem
*.key

# --- Talamus brains created inside the repo (derived caches, never truth) ---
.talamus/

# --- Downloaded benchmark datasets (BEIR etc.) — regenerable, never committed ---
.bench-data/

# --- Transient CI-tier benchmark artifacts (real shootout results stay tracked) ---
benchmarks/results/*-ci.json
benchmarks/results/*-ci.md

# --- Built docs site (mkdocs build output) ----------------------------------
site/

# --- Local UI demo brains + dev server logs (created by `talamus ui` tests) --
.uidemo/
.uidemo*/
*_server.log

# --- Node / web workbench build inputs (the built SPA under src/ IS tracked) -
webui/node_modules/

# --- OS cruft (multi-OS: macOS / Windows / Linux) ---------------------------
.DS_Store
.AppleDouble
Thumbs.db
desktop.ini
$RECYCLE.BIN/
*~

# --- Editor / IDE cruft -----------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*.sublime-workspace

# --- Scratch ----------------------------------------------------------------
*.tmp
*.temp
~$*

# benchmark judge cache (generated, machine-local)
benchmarks/results/.judge-cache.json
